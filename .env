# =========================================
# Frontend Environment Variables
# =========================================

# Main backend API base URL
# Example local: http://localhost:5000/api/v1
# Example prod:  https://api.bookuz.uz/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Enable bundle analyzer in Next.js build
# true | false
BUNDLE_ANALYZER_ENABLED=false


# =========================================
# API Endpoint Reference
# This section is for documentation only.
# These lines are comments and are not used by Next.js directly.
# =========================================

# Auth
# POST   /auth/register
# POST   /auth/login
# POST   /auth/refresh
# POST   /auth/logout
# POST   /auth/forgot-password
# POST   /auth/reset-password

# User / Profile
# GET    /users/profile
# PATCH  /users/profile
# PATCH  /users/update-password
# GET    /users/wishlist
# POST   /users/wishlist/toggle
# GET    /users/addresses
# POST   /users/address
# DELETE /users/address/:addressId
# GET    /users/notifications
# PUT    /users/notifications
# GET    /users/security
# PUT    /users/security
# GET    /users/preferences
# PUT    /users/preferences
# GET    /users/devices
# DELETE /users/devices/:deviceId
# DELETE /users/account

# Products / Catalog / Search
# GET    /products
# GET    /products/:id
# GET    /products/:id/related
# GET    /search
# GET    /search/suggestions

# Categories
# GET    /categories?all=true
# GET    /categories/:slug
# GET    /categories/:slug/products

# Admin Categories
# GET    /admin/categories
# POST   /admin/categories
# PATCH  /admin/categories/:id
# DELETE /admin/categories/:id
# POST   /admin/categories/sub
# DELETE /admin/categories/:categoryId/sub/:subId
# PATCH  /admin/categories/:id/toggle-status
# PATCH  /admin/categories/:id/toggle-featured

# Audio Books
# GET    /audio-books
# GET    /audio-books/:id
# GET    /audio-books/slug/:slug
# POST   /audio-books/:id/download

# Banners
# GET    /banners
# GET    /banners?type=hero
# GET    /banners?type=author
# GET    /banners?type=quote
# GET    /banners?type=news
# POST   /banners/:bannerId/view
# POST   /banners/:bannerId/click

# Cart / Checkout / Coupons
# GET    /cart
# POST   /cart/add
# PATCH  /cart/update
# DELETE /cart/remove/:productId
# DELETE /cart/clear
# POST   /cart/apply-promo
# POST   /coupons/apply

# Orders
# POST   /orders
# GET    /orders/my-orders
# GET    /orders/:id
# GET    /orders/check-purchased/:productId
# PUT    /orders/:id/cancel
# POST   /orders/:id/reorder

# Reviews
# GET    /reviews/product/:productId
# GET    /reviews/user/product/:productId
# POST   /reviews
# PUT    /reviews/:reviewId
# DELETE /reviews/:reviewId
# POST   /reviews/:reviewId/reply
# POST   /reviews/:reviewId/like

# Promo / News / Subscription
# GET    /promo-codes?active=true
# GET    /news?active=true&page=:page&limit=:limit
# GET    /news/:slug
# POST   /news/:slug/view
# POST   /news/:slug/like
# GET    /news?related=:slug&limit=3
# GET    /subscription/plans
# POST   /subscription/subscribe

# Misc
# POST   /newsletter/subscribe
